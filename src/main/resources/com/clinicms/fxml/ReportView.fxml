<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.clinicms.controller.ReportController"
      spacing="14" styleClass="view-root">

    <HBox alignment="CENTER_LEFT" spacing="12">
        <Label text="Αναφορες Ραντεβου" styleClass="section-title"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Label fx:id="lblCount" styleClass="form-label"/>
    </HBox>

    <HBox spacing="12" alignment="CENTER_LEFT" styleClass="filter-bar">
        <padding><Insets top="8" right="12" bottom="8" left="12"/></padding>
        <Label text="Κατασταση:" styleClass="form-label"/>
        <ComboBox fx:id="cbStatusFilter" prefWidth="160"/>
        <Label text="Ιατρος:" styleClass="form-label"/>
        <TextField fx:id="tfDoctorFilter" promptText="Φιλτρο με ονομα ιατρου..." prefWidth="180"/>
        <Label text="Ασθενης:" styleClass="form-label"/>
        <TextField fx:id="tfPatientFilter" promptText="Φιλτρο με ονομα ασθενη..." prefWidth="180"/>
        <Button text="Καθαρισμος Φιλτρων" onAction="#onClearFilters" styleClass="btn-secondary"/>
    </HBox>

    <TableView fx:id="reportTable" VBox.vgrow="ALWAYS" styleClass="data-table">
        <columns>
            <TableColumn fx:id="colId"        text="ΑΑ"          prefWidth="45"/>
            <TableColumn fx:id="colPatient"   text="Ασθενης"     prefWidth="150"/>
            <TableColumn fx:id="colDoctor"    text="Ιατρος"      prefWidth="150"/>
            <TableColumn fx:id="colSpecialty" text="Ειδικοτητα"  prefWidth="120"/>
            <TableColumn fx:id="colDate"      text="Ημερομηνια"  prefWidth="100"/>
            <TableColumn fx:id="colTime"      text="Ωρα"         prefWidth="65"/>
            <TableColumn fx:id="colReason"    text="Αιτια"       prefWidth="160"/>
            <TableColumn fx:id="colStatus"    text="Κατασταση"   prefWidth="110"/>
            <TableColumn fx:id="colNotes"     text="Σημειωσεις"  prefWidth="150"/>
        </columns>
        <placeholder><Label text="Δεν βρεθηκαν εγγραφες με τα τρεχοντα φιλτρα."/></placeholder>
    </TableView>

    <HBox spacing="12" alignment="CENTER_LEFT">
        <Button text="Εξαγωγη σε αρχειο report.txt" onAction="#onExport" styleClass="btn-primary"/>
        <Label fx:id="lblExportStatus" styleClass="status-label"/>
    </HBox>
</VBox>
