<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.clinicms.controller.MainController"
            styleClass="root-pane">

    <top>
        <HBox styleClass="app-header" alignment="CENTER_LEFT" spacing="16">
            <padding><Insets top="14" right="24" bottom="14" left="24"/></padding>
            <VBox>
                <Label text="Συστημα Διαχειρισης Κλινικης" styleClass="app-title"/>
                <Label text="CN5004 · Προχωρημενος Προγραμματισμος" styleClass="app-subtitle"/>
            </VBox>
        </HBox>
    </top>

    <left>
        <VBox styleClass="sidebar" spacing="6" minWidth="200">
            <padding><Insets top="24" right="12" bottom="24" left="12"/></padding>
            <Label text="ΠΛΟΗΓΗΣΗ" styleClass="nav-section-label"/>
            <Button text="Ιατροι"   onAction="#showDoctors"      styleClass="nav-btn" maxWidth="Infinity"/>
            <Button text="Ασθενεις" onAction="#showPatients"     styleClass="nav-btn" maxWidth="Infinity"/>
            <Button text="Ραντεβου" onAction="#showAppointments" styleClass="nav-btn" maxWidth="Infinity"/>
        </VBox>
    </left>

    <center>
        <StackPane fx:id="contentArea" styleClass="content-area">
            <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>
        </StackPane>
    </center>
</BorderPane>
